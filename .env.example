NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
# LOG_LEVEL: debug | info (défaut) | warn | error | silent
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=budget_db

# ─── Production hébergée (Aiven / Heroku Postgres) ─────────────────
# DATABASE_URL : chaîne de connexion unique. Si présente, elle est
# prioritaire sur les 5 variables DB_* ci-dessus. C'est ce que fournit
# Aiven (« Service URI ») ou l'add-on Heroku Postgres. NE JAMAIS
# committer une vraie valeur — la définir dans les Config Vars Heroku.
# Exemple Aiven : postgres://avnadmin:MOTDEPASSE@pg-xxxx.aivencloud.com:PORT/defaultdb?sslmode=require
# DATABASE_URL=
#
# DB_SSL : mettre `true` en prod (Aiven/Heroku imposent TLS). Laisser
# absent/false en local (Postgres sans TLS).
DB_SSL=false

# ─── Redis / BullMQ ────────────────────────────────────────────────
# En local : Redis docker sans TLS. En prod (Aiven/Heroku Redis) :
# renseigner l'hôte/port/mot de passe fournis et REDIS_TLS=true.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# JWT_SECRET DOIT être généré aléatoirement (>= 64 octets) et NE JAMAIS être committé.
# Génération : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_random_64_byte_hex_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Mot de passe initial du compte admin@miznas.local — À CHANGER DÈS LE 1er LOGIN.
SEED_ADMIN_PASSWORD=ChangeMe!2026

# ─── Lot 4.3 — Notifications email ─────────────────────────────────
# Configuration SMTP. En dev, recommander Mailhog (https://mailhog.io)
# qui écoute par défaut sur localhost:1025 sans auth ni TLS.
# Pour la prod : SMTP institutionnel BSIC avec STARTTLS.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=miznas@bsic.local

# Mode dry-run : si true, aucun email n'est réellement envoyé via SMTP,
# mais une ligne email_log est créée avec statut='SUPPRIME'. Permet
# démos et CI sans serveur SMTP. Défaut : true en dev.
EMAIL_DRY_RUN=true

# URL absolue de l'application (utilisée dans les liens des emails).
APP_BASE_URL=http://localhost:5173

# ─── Lot 6.4.B — Rate limiting login ───────────────────────────────
# Le LoginRateLimitGuard bloque POST /auth/login à 5 tentatives/60s par
# IP et 5 tentatives/15min par email. En dev local, mettre à `true`
# pour ne pas bloquer Playwright + tests manuels qui enchaînent
# plusieurs logins de personas différents depuis localhost en
# quelques secondes. NE JAMAIS activer en pré-prod ou en production.
LOGIN_RATE_LIMIT_DISABLED=false

# ─── Lot 8.1.D — Upload PDF documents officiels ──────────────────
# Chemin de stockage des PDF originaux attachés aux documents
# officiels (Lettre cadrage, Note orientation, PV, etc.). Structure :
#   <DOCUMENTS_UPLOAD_PATH>/<exerciceFiscal>/<codeDocument>.pdf
# Conservation 10 ans (BCEAO). Le contenu N'EST PAS commité (cf.
# .gitignore). En prod, pointer vers un volume monté ou un bucket S3
# via un service de stockage dédié.
DOCUMENTS_UPLOAD_PATH=./uploads/documents

# ─── Lot 8.6.A — MIZNAS AI Analyse Budget vs Réalisé ─────────────
# Clé API Anthropic (https://console.anthropic.com/settings/keys).
# OBLIGATOIRE en prod. En dev, peut rester vide si AI_DRY_RUN=true
# (le service renvoie alors une réponse mockée sans appel SDK).
ANTHROPIC_API_KEY=
# Modèle Claude utilisé. Défaut : claude-sonnet-4-6 (Sonnet le plus
# récent, ~0.024 $ / analyse pour 3K tokens input + 1K output).
# Alternatives : claude-opus-4-7 (analyses plus profondes, ~5× plus
# cher) ou claude-haiku-4-5-20251001 (plus rapide / moins cher).
ANTHROPIC_MODEL=claude-sonnet-4-6
# Mode dry-run : si true, aucun appel SDK réel — le service renvoie
# une analyse mockée déterministe. Permet démos + tests + CI sans
# clé API. Défaut : true en dev pour éviter facturation accidentelle.
AI_DRY_RUN=true
# Désactivation du rate limiter MIZNAS AI (cf. AiAnalyseRateLimiter).
# Limites par défaut : 3 analyses / minute + 10 / jour par
# utilisateur. À laisser à `false` (ou retirer) en prod pour
# protéger le budget Anthropic.
AI_RATE_LIMIT_DISABLED=false
