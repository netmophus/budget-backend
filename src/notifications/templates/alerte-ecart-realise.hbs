<thead>
<tr style="background:#f6f8fa; color:#656d76;">
<th style="text-align:left; padding:6px 10px; border-bottom:1px solid #d0d7de;">Compte</th>
<th style="text-align:left; padding:6px 10px; border-bottom:1px solid #d0d7de;">CR</th>
<th style="text-align:right; padding:6px 10px; border-bottom:1px solid #d0d7de;">Budget</th>
<th style="text-align:right; padding:6px 10px; border-bottom:1px solid #d0d7de;">Réalisé</th>
<th style="text-align:right; padding:6px 10px; border-bottom:1px solid #d0d7de;">Écart</th>
</tr>
</thead>
<tbody>
{{#each critiques}}
<tr>
<td style="padding:4px 10px; border-bottom:1px solid #eaeef2;"><strong>{{codeCompte}}</strong> {{libelleCompte}}</td>
<td style="padding:4px 10px; border-bottom:1px solid #eaeef2;">{{codeCr}}</td>
<td style="padding:4px 10px; border-bottom:1px solid #eaeef2; text-align:right;">{{montantBudgetFormatte}}</td>
<td style="padding:4px 10px; border-bottom:1px solid #eaeef2; text-align:right;">{{montantRealiseFormatte}}</td>
<td style="padding:4px 10px; border-bottom:1px solid #eaeef2; text-align:right; color:#cf222e;"><strong>{{ecartPctFormatte}}</strong></td>
</tr>
{{/each}}
</tbody>
</table>
